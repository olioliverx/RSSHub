{
    "name": "shlibrary-watch",
    "version": "1.0.0",
    "private": true,
    "description": "Monitor Shanghai Library (VuFind) book availability with RSS and Telegram notifications",
    "type": "module",
    "scripts": {
        "start": "tsx src/index.ts",
        "dev": "tsx watch src/index.ts",
        "check": "tsc --noEmit",
        "test": "node --import tsx --test src/shlibrary.test.ts"
    },
    "dependencies": {
        "@hono/node-server": "^1.14.4",
        "hono": "^4.8.3"
    },
    "devDependencies": {
        "@types/node": "^22.15.21",
        "tsx": "^4.20.3",
        "typescript": "^5.8.3"
    }
}
